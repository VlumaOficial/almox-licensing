# Configuração do Almox-Licensing - Módulo 1
# Copie este arquivo para .env e ajuste os valores

# Ambiente
NODE_ENV=development

# Configuração do Supabase (OBRIGATÓRIO)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configuração da API
API_BASE_URL=https://almox-licensing.vercel.app

# Segurança
ENCRYPTION_KEY=almox-licensing-2024-secure-key-change-in-production
JWT_SECRET=your-jwt-secret-here

# Validação
VALIDATION_INTERVAL=3600000  # 1 hora em milissegundos
TRIAL_DURATION_DAYS=7
MAX_VALIDATION_ATTEMPTS=3

# ASAAS (será usado no Módulo 3)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_SECRET=your-webhook-secret

# Email (será usado no Módulo 4)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@almox-licensing.com

# Admin
ADMIN_EMAIL=admin@almox-licensing.com
ADMIN_PASSWORD=secure-admin-password-change-in-production

# Debug
DEBUG=almox-licensing:*
