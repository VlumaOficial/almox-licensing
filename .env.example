# Configuração do Módulo de Licenciamento AlmoxPro
# Copie este arquivo para .env e ajuste os valores

# Ambiente
NODE_ENV=development

# Configuração da API
LICENSING_API_ENDPOINT=https://almox-five.vercel.app/api/v1
LICENSING_API_KEY=your-api-key-here

# Configuração do Supabase
SUPABASE_URL=postgresql://postgres.ckkzvzvqgoyxwzzqwhqjx.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Segurança
LICENSING_ENCRYPTION_KEY=almox-pro-2024-secure-key-change-in-production

# Validação
LICENSING_ONLINE_CHECK_INTERVAL=60
LICENSING_OFFLINE_GRACE_PERIOD=7
LICENSING_MAX_MACHINES=5

# Debug
DEBUG=almox-licensing:*
